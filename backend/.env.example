# ===== 真实 LLM 配置 =====
# DeepSeek 官方平台：https://platform.deepseek.com
LLM_API_KEY=sk-your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ===== Tavily 搜索 API（竞品分析联网搜索用）=====
# 免费注册获取 Key：https://app.tavily.com
TAVILY_API_KEY=tvly-your-tavily-key

# ===== PostgreSQL 数据库配置 =====
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=shenxingdb
DB_USER=postgres
DB_PASSWORD=your-db-password

# ===== JWT 鉴权密钥（随机生成，切勿提交；泄露后需轮换）=====
# 可用 python -c "import secrets;print(secrets.token_urlsafe(48))" 生成
JWT_SECRET=please-generate-a-random-secret
# 黑名单查询进程内缓存 TTL（秒），默认 5；无 Redis 时的过渡方案
JWT_BLACKLIST_CACHE_TTL=5

# ===== 运行环境与 CORS 跨域 =====
# development（默认，CORS 放行所有来源）/ production（必须配 ALLOWED_ORIGINS，否则启动报错）
APP_ENV=development
# 生产环境合法前端域名，逗号分隔：ALLOWED_ORIGINS=https://a.com,https://b.com
ALLOWED_ORIGINS=
