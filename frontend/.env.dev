NODE_ENV=development
VITE_APP_ENV=dev
VITE_PORT=53200
# 开发环境后端 API 地址
# VITE_API_TARGET=http://localhost:8080
VITE_API_TARGET=http://localhost:8000
# 鉴权域 Mock 开关：后端就绪后改为 false
# VITE_APP_USE_MOCK_AUTH=true
VITE_APP_USE_MOCK_AUTH=false
# 业务域 Mock 开关：后端就绪后改为 false，产品/模板/生成等接口自动切到真实链路
# VITE_APP_USE_MOCK_BIZ=true
VITE_APP_USE_MOCK_BIZ=false
